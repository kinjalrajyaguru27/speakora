            },
            {
                "name": "Past Simple",
                "description": "Finished action.",
                "examples": [
                    "I ate."
                ]
            },
            {
                "name": "Past Continuous",
                "description": "Ongoing in the past.",
                "examples": [
                    "I was eating."
                ]
            },
            {
                "name": "Past Perfect",
                "description": "Finished before another past action.",
                "examples": [
                    "I had eaten."
                ]
            },
            {
                "name": "Past Perfect Continuous",
                "description": "Continued up to a point in the past.",
