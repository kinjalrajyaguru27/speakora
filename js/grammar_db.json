                "description": "Action happening now.",
                "examples": [
                    "I am eating."
                ]
            },
            {
                "name": "Present Perfect",
                "description": "Completed recently with relevance now.",
                "examples": [
                    "I have eaten."
                ]
            },
            {
                "name": "Present Perfect Continuous",
                "description": "Started in past and continuing.",
                "examples": [
                    "I have been eating."
